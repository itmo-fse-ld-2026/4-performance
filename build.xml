<project xmlns:ivy="antlib:org.apache.ivy.ant">
  <property file="build.properties"/>

  <path id="fse.java.classpath">
    <fileset dir="${user.home}/.ant/lib">
      <include name="*.jar"/>
    </fileset>
  </path>

  <target name="compile">
    <echo message="[WIP] Compiling..."/>
  </target>

  <target name="build" depends="compile">
    <echo message="[WIP] Building..."/>
  </target>

  <target name="music" depends="build">
    <sound>
      <success source="${fse.ant.resources}/sounds/build_success.wav"/>
    </sound>
  </target>

  <target name="resolve">
    <ivy:retrieve
        pattern="${user.home}/.ant/lib/[artifact]-[revision](-[classifier]).[ext]" />
  </target>

  <target name="diff">
    <echo message="Checking for changes in target classes..." />
    <java classname="org.tmatesoft.svn.cli.SVN"
          outputproperty="fse.diff.out"
          fork="true">
      <classpath refid="fse.java.classpath"/>

      <arg value="status"/>
    </java>

    <condition property="fse.diff.detected">
      <matches string="${fse.diff.out}" pattern="${fse.diff.classes}"/>
    </condition>

    <antcall target="-svn-commit-if-changed"/>
    <echo message="Done!" />
  </target>

  <target name="-svn-commit-if-changed" if="fse.diff.detected">
    <echo message="Target classes modified. Committing to SVN..."/>
    <java classname="org.tmatesoft.svn.cli.SVN"
          fork="true">
      <classpath refid="fse.java.classpath"/>

      <arg value="commit"/>
      <arg value="-m"/>
      <arg value="feat: changes in tracked classes (Ant-automated)"/>
      <arg value="."/>
    </java>
  </target>

</project>